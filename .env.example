# ============================================================
# ReviewReplyOrchestrator – Environment Configuration Template
# Copy this file to engine.env and fill in your real values.
# NEVER commit engine.env or .env to source control.
# ============================================================

# --- Server ---
ENGINE_HOST=127.0.0.1
ENGINE_PORT=7363
DATA_ROOT=./data

# --- AI Backend (choose one or both) ---
OLLAMA_URL=http://127.0.0.1:11434
LMSTUDIO_URL=http://127.0.0.1:1234/v1/chat/completions
REPLY_MODEL=qwen2.5:7b-instruct

# --- Google OAuth2 (for GMB API integration) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:7363/oauth/callback

# --- Stripe Payment Processing (optional) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Review Monitoring ---
REVIEW_CHECK_INTERVAL_MINUTES=60
REVIEW_DB_PATH=./data/reviews.db
TOKEN_STORAGE_PATH=./tokens/google_tokens.json

# --- Credential Encryption ---
FERNET_KEY_PATH=./tokens/fernet.key

# --- Sellable Bot (only needed when running sellable/ variant) ---
# LICENSE_MASTER_KEY is the secret used to generate/validate customer licenses.
# Change this before distributing the sellable bot. Keep it secret!
LICENSE_MASTER_KEY=change-me-before-distributing
